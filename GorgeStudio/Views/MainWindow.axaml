<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GorgeStudio.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="GorgeStudio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="GorgeStudio"
        Width="1920" Height="1200">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto,300,Auto">
        <!-- 工具栏 -->
        <Border Grid.Row="0"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                Padding="8,6"
                BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="GorgeStudio"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Separator Width="1" Height="20"
                           Background="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
                           VerticalAlignment="Center" />
                <Button Content="加载Godot运行核心"
                        Command="{Binding LaunchCommand}"
                        IsEnabled="{Binding CanLaunch}" />
            </StackPanel>
        </Border>

        <!-- Row 1: Embed area + Right panel -->
        <Grid Grid.Row="1" ColumnDefinitions="*,4,350,4,350">
            <!-- Left: Godot embed area -->
            <Border x:Name="EmbedHost"
                    Grid.Column="0"
                    Background="Black"
                    Focusable="False" />

            <!-- Resize handle -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          Background="Gray"
                          ResizeDirection="Columns" />

            <!-- Right: Properties panel -->
            <Border Grid.Column="2"
                    MinWidth="150"
                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
                    BorderThickness="1,0,0,0">
                <ContentControl Content="{Binding RightPanel}" />
            </Border>

            <!-- Resize handle -->
            <GridSplitter Grid.Column="3"
                          Width="4"
                          Background="Gray"
                          ResizeDirection="Columns" />

            <!-- Element List panel -->
            <Border Grid.Column="4"
                    MinWidth="150"
                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
                    BorderThickness="1,0,0,0">
                <ContentControl Content="{Binding ElementListPanel}" />
            </Border>
        </Grid>

        <!-- Row 2: Resize handle (horizontal) -->
        <GridSplitter Grid.Row="2"
                      Height="4"
                      Background="Gray"
                      ResizeDirection="Rows" />

        <!-- Timeline -->
        <ContentControl Grid.Row="3"
                        Content="{Binding TimelinePanel}" />

        <!-- 状态栏 -->
        <Border Grid.Row="4"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                Padding="8,4"
                BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Opacity="0.7" />
        </Border>
    </Grid>

</Window>
