<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GorgeStudio.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="GorgeStudio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="GorgeStudio"
        Width="1920" Height="1200">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*,Auto,300,Auto">
        <!-- Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="文件">
                <MenuItem Header="打开"
                          Command="{Binding LoadZipCommand}"
                          IsEnabled="{Binding CanLaunch}" />
                <Separator />
                <MenuItem Header="保存"
                          Command="{Binding SaveCommand}"
                          IsEnabled="{Binding CanLaunch}" />
                <MenuItem Header="另存为"
                          Command="{Binding SaveAsCommand}"
                          IsEnabled="{Binding CanLaunch}" />
            </MenuItem>
            <MenuItem Header="项目">
                <MenuItem Header="项目设置"
                          Command="{Binding OpenProjectSettingsCommand}" />
            </MenuItem>
            <MenuItem Header="模态">
                <MenuItem Header="管理模式..."
                          Command="{Binding ManageFormsCommand}"
                          IsEnabled="{Binding CanLaunch}" />
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Border Grid.Row="1" Classes="toolbar">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Classes="subtitle"
                           Text="GorgeStudio"
                           VerticalAlignment="Center" />
                <Separator Width="1" Height="22"
                           Background="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
                           VerticalAlignment="Center" />
                <Button Classes="accent"
                        Content="加载Godot运行核心"
                        Command="{Binding LaunchCommand}"
                        IsEnabled="{Binding CanLaunch}" />
            </StackPanel>
        </Border>

        <!-- Row 2: Embed area + Right panel -->
        <Grid Grid.Row="2" ColumnDefinitions="*,4,350,4,350">
            <!-- Left: Godot embed area -->
            <Border x:Name="EmbedHost"
                    Grid.Column="0"
                    Background="Black"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
                    BorderThickness="1"
                    Focusable="False" />

            <GridSplitter Grid.Column="1"
                          Width="4"
                          ResizeDirection="Columns" />

            <!-- Right: Properties panel -->
            <Border Grid.Column="2"
                    MinWidth="150"
                    Classes="cardPanel"
                    BorderThickness="1,0,0,0"
                    CornerRadius="0">
                <ContentControl Content="{Binding RightPanel}" />
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="4"
                          ResizeDirection="Columns" />

            <!-- Element List panel -->
            <Border Grid.Column="4"
                    MinWidth="150"
                    Classes="cardPanel"
                    BorderThickness="1,0,0,0"
                    CornerRadius="0">
                <ContentControl Content="{Binding ElementListPanel}" />
            </Border>
        </Grid>

        <!-- Row 3: Resize handle (horizontal) -->
        <GridSplitter Grid.Row="3"
                      Height="4"
                      ResizeDirection="Rows" />

        <!-- Timeline -->
        <ContentControl Grid.Row="4"
                        Content="{Binding TimelinePanel}" />

        <!-- Status bar -->
        <Border Grid.Row="5" Classes="statusBar">
            <TextBlock Classes="statusBarText"
                       Text="{Binding StatusText}"
                       VerticalAlignment="Center" />
        </Border>
    </Grid>

</Window>
