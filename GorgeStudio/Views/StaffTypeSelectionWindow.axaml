<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GorgeStudio.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="350"
        x:Class="GorgeStudio.Views.StaffTypeSelectionWindow"
        x:DataType="vm:StaffTypeSelectionWindowViewModel"
        Title="选择谱表类型"
        Width="400" Height="350"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:StaffTypeSelectionWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Padding="20,16,20,8">
            <TextBlock Text="选择要创建的谱表类型"
                       FontSize="15" FontWeight="SemiBold" />
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="20,0" Spacing="12">
            <!-- Staff type selection -->
            <ListBox ItemsSource="{Binding StaffTypes}"
                     SelectedItem="{Binding SelectedStaffType, Mode=TwoWay}"
                     BorderThickness="0"
                     MinHeight="80">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:StaffTypeOption">
                        <Border Padding="8,6">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Form selector (visible when ElementStaff is selected) -->
            <StackPanel Spacing="4"
                        IsVisible="{Binding SelectedStaffType.RequiresForm}">
                <TextBlock Text="选择模态（Form）"
                           FontSize="13"
                           Foreground="{DynamicResource SystemControlBackgroundBaseMediumBrush}" />
                <ComboBox ItemsSource="{Binding Forms}"
                          SelectedItem="{Binding SelectedForm, Mode=TwoWay}"
                          PlaceholderText="请选择模态..."
                          MinHeight="32" />
            </StackPanel>
        </StackPanel>

        <!-- Bottom button bar -->
        <Border Grid.Row="2"
                Padding="16,12"
                BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="8">
                <Button Content="确定" Classes="accent"
                        Command="{Binding OkCommand}"
                        IsEnabled="{Binding IsSelectionValid}" />
                <Button Content="取消"
                        Command="{Binding CancelCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
