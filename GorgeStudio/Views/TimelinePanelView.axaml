<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GorgeStudio.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="200"
             x:Class="GorgeStudio.Views.TimelinePanelView"
             x:DataType="vm:TimelinePanelViewModel">

    <Design.DataContext>
        <vm:TimelinePanelViewModel/>
    </Design.DataContext>

    <Border Classes="cardPanel" CornerRadius="0" BorderThickness="0,1,0,0">
        <DockPanel>
            <!-- Header strip -->
            <Border DockPanel.Dock="Top" Classes="panelHeader">
                <TextBlock Classes="subtitle" Text="{Binding Title}" />
            </Border>

            <!-- Timeline content area -->
            <Grid Margin="16,8">
                <TextBlock Classes="caption"
                           Text="Timeline content area"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>
        </DockPanel>
    </Border>

</UserControl>
