<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GorgeStudio.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="200"
             x:Class="GorgeStudio.Views.TimelinePanelView"
             x:DataType="vm:TimelinePanelViewModel">

    <Design.DataContext>
        <vm:TimelinePanelViewModel/>
    </Design.DataContext>

    <Border Classes="cardPanel" CornerRadius="0" BorderThickness="0,1,0,0">
        <DockPanel>
            <!-- Header strip -->
            <Border DockPanel.Dock="Top" Classes="panelHeader">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
                    <TextBlock Grid.Column="0" Classes="subtitle" Text="{Binding Title}" VerticalAlignment="Center" />
                    <Separator Grid.Column="1" Width="1" Height="16" Margin="12,0"
                               Background="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" Margin="0,0,12,0">
                        <Button Content="-" Width="28" Height="28" Padding="0"
                                Click="ZoomOut_Click" ToolTip.Tip="缩小" />
                        <Button Content="+" Width="28" Height="28" Padding="0"
                                Click="ZoomIn_Click" ToolTip.Tip="放大" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Timeline canvas area -->
            <ScrollViewer x:Name="TimelineScroller"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Hidden"
                          ScrollChanged="OnScrollChanged">
                <Canvas x:Name="TimelineCanvas"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        Height="160"
                        Width="2000" />
            </ScrollViewer>
        </DockPanel>
    </Border>

</UserControl>
