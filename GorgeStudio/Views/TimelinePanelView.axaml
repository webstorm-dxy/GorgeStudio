<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GorgeStudio.ViewModels"
             xmlns:controls="using:GorgeStudio.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="200"
             x:Class="GorgeStudio.Views.TimelinePanelView"
             x:DataType="vm:TimelinePanelViewModel">

    <Design.DataContext>
        <vm:TimelinePanelViewModel/>
    </Design.DataContext>

    <Border Classes="cardPanel" CornerRadius="0" BorderThickness="0,1,0,0">
        <Grid RowDefinitions="Auto,*">

            <!-- Header strip -->
            <Border Grid.Row="0" Classes="panelHeader">
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Classes="subtitle"
                               Text="{Binding Title}"
                               VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <TextBlock Text="吸附"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <ComboBox ItemsSource="{Binding SnapModeOptions}"
                                  SelectedItem="{Binding SelectedSnapModeOption, Mode=TwoWay}"
                                  Width="92"
                                  Height="26">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:SnapModeOption">
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Timeline body: frozen-header Grid -->
            <Grid Grid.Row="1" ColumnDefinitions="180,*" RowDefinitions="Auto,*">

                <!-- ===== LEFT COLUMN ===== -->

                <!-- Area A: Toolbar (Row 0, Col 0) -->
                <Border Grid.Row="0" Grid.Column="0"
                        Padding="6,4"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,*,*,*">
                        <Button Grid.Column="0"
                                Content="＋" Height="26" Margin="2,0"
                                Command="{Binding AddTrackCommand}"
                                ToolTip.Tip="Add Track" />
                        <Button Grid.Column="1"
                                Content="－" Height="26" Margin="2,0"
                                Command="{Binding DeleteTrackCommand}"
                                ToolTip.Tip="Delete Track" />
                        <Button Grid.Column="2"
                                Content="⊞" Height="26" Margin="2,0"
                                Command="{Binding CopyTrackCommand}"
                                ToolTip.Tip="Copy Track" />
                        <Button Grid.Column="3"
                                Content="⚙" Height="26" Margin="2,0"
                                Command="{Binding OpenSettingsCommand}"
                                ToolTip.Tip="Settings" />
                    </Grid>
                </Border>

                <!-- Area B: Track name list (Row 1, Col 0) -->
                <ScrollViewer Grid.Row="1" Grid.Column="0"
                              x:Name="TrackNameScroller"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Hidden">
                    <ListBox ItemsSource="{Binding Tracks}"
                             SelectedIndex="{Binding SelectedTrackIndex, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="40" />
                                <Setter Property="Height" Value="40" />
                            </Style>
                            <Style Selector="ListBoxItem:selected">
                                <Setter Property="Background" Value="#234A6C" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TrackInfo">
                                <Border Height="40" Padding="10,0"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}"
                                        BorderThickness="0,0,0,1">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- ===== RIGHT COLUMN ===== -->

                <!-- Area C: Time ruler (Row 0, Col 1) -->
                <ScrollViewer Grid.Row="0" Grid.Column="1"
                              x:Name="RulerScroller"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <controls:TimelineRuler x:Name="RulerControl"
                        Height="36"
                        PixelsPerSecond="{Binding PixelsPerSecond}"
                        Bpm="{Binding Bpm}"
                        BeatsPerBar="{Binding BeatsPerBar}"
                        SubdivisionsPerBeat="{Binding SubdivisionsPerBeat}"
                        TotalDurationSeconds="{Binding TotalDuration}"
                        OffsetMilliseconds="{Binding Offset}" />
                </ScrollViewer>

                <!-- Area E: Main track editing area (Row 1, Col 1) -->
                <!-- Area D: Playhead drawn inside TimelineTrackArea -->
                <!-- Area F: Scrollbars provided by this ScrollViewer -->
                <ScrollViewer Grid.Row="1" Grid.Column="1"
                              x:Name="TrackScroller"
                              HorizontalScrollBarVisibility="Visible"
                              VerticalScrollBarVisibility="Visible"
                              AllowAutoHide="False"
                              ScrollChanged="OnTrackScrollerScrollChanged">
                    <controls:TimelineTrackArea x:Name="TrackAreaControl"
                        PointerPressed="OnTrackAreaPointerPressed"
                        PointerMoved="OnTrackAreaPointerMoved"
                        PointerReleased="OnTrackAreaPointerReleased"
                        PixelsPerSecond="{Binding PixelsPerSecond}"
                        PlayheadPositionSeconds="{Binding PlayheadPosition}"
                        TrackCount="{Binding TrackCount}"
                        Tracks="{Binding Tracks}"
                        TrackRowHeight="40"
                        TotalDurationSeconds="{Binding TotalDuration}"
                        SelectedTrackIndex="{Binding SelectedTrackIndex}">
                        <controls:TimelineTrackArea.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Period" Command="{Binding AddPeriodCommand}"
                                          IsEnabled="{Binding CanAddPeriod}" />
                                <Separator />
                                <MenuItem Header="Copy Period" Command="{Binding CopyPeriodCommand}"
                                          IsEnabled="{Binding CanCopyPeriod}" />
                                <MenuItem Header="Delete Period" Command="{Binding DeletePeriodCommand}"
                                          IsEnabled="{Binding CanDeletePeriod}" />
                            </ContextMenu>
                        </controls:TimelineTrackArea.ContextMenu>
                    </controls:TimelineTrackArea>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Border>

</UserControl>
