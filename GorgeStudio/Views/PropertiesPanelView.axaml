<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GorgeStudio.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="400"
             x:Class="GorgeStudio.Views.PropertiesPanelView"
             x:DataType="vm:PropertiesPanelViewModel">

    <Design.DataContext>
        <vm:PropertiesPanelViewModel/>
    </Design.DataContext>

    <Border Classes="cardPanel" CornerRadius="0" BorderThickness="0">
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Classes="panelHeader">
                <TextBlock Classes="subtitle" Text="{Binding Title}" />
            </Border>

            <!-- Content -->
            <ScrollViewer>
                <StackPanel Orientation="Vertical" Spacing="12" Margin="16">
                    <TextBlock Classes="caption"
                               Text="{Binding Description}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>

</UserControl>
