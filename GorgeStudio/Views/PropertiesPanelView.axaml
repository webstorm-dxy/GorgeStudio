<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GorgeStudio.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="400"
             x:Class="GorgeStudio.Views.PropertiesPanelView"
             x:DataType="vm:PropertiesPanelViewModel">

    <Design.DataContext>
        <vm:PropertiesPanelViewModel/>
    </Design.DataContext>

    <Border Classes="cardPanel" CornerRadius="0" BorderThickness="0">
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top" Classes="panelHeader">
                <TextBlock Classes="subtitle" Text="{Binding Title}" />
            </Border>

            <!-- Property grid -->
            <ScrollViewer>
                <StackPanel Spacing="0">
                    <!-- Description line -->
                    <Border Padding="16,8" BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}">
                        <TextBlock Classes="caption"
                                   Text="{Binding Description}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <!-- Property entries -->
                    <ItemsControl ItemsSource="{Binding Properties}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="120,*,8"
                                      Margin="0">
                                    <Border Grid.Column="0"
                                            Padding="16,4,8,4"
                                            BorderThickness="0,0,1,0"
                                            BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <Border Grid.Column="1"
                                            Padding="8,4,16,4">
                                        <TextBlock Text="{Binding Value}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>

</UserControl>
