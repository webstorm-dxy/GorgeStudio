<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GorgeStudio.App"
             xmlns:local="using:GorgeStudio"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://GorgeStudio/Styles/SharedBrushes.axaml" />
        <StyleInclude Source="avares://GorgeStudio/Styles/SharedTypography.axaml" />
        <StyleInclude Source="avares://GorgeStudio/Styles/SharedStyles.axaml" />
    </Application.Styles>
</Application>