<Styles xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base TextBlock: Inter font, default size, auto light/dark foreground -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource ControlContentThemeFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    </Style>

    <!-- Caption: small secondary text (11px, 60% opacity) -->
    <Style Selector="TextBlock.caption">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Opacity" Value="0.6" />
    </Style>

    <!-- BodyStrong: emphasised body text (13px, SemiBold) -->
    <Style Selector="TextBlock.bodyStrong">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Subtitle: panel titles / section headers (16px, SemiBold) -->
    <Style Selector="TextBlock.subtitle">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Status bar text: compact monochrome (12px, 70% opacity) -->
    <Style Selector="TextBlock.statusBarText">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Opacity" Value="0.7" />
    </Style>

</Styles>
