<Styles xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Toolbar ===== -->
    <Style Selector="Border.toolbar">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseMediumBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="16,10" />
    </Style>

    <!-- ===== Card-style panel ===== -->
    <Style Selector="Border.cardPanel">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseMediumBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <!-- ===== Panel header (bottom 1px divider) ===== -->
    <Style Selector="Border.panelHeader">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseMediumBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <!-- ===== Status bar ===== -->
    <Style Selector="Border.statusBar">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseMediumBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="16,6" />
    </Style>

    <!-- ===== GridSplitter ===== -->
    <Style Selector="GridSplitter">
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumBrush}" />
    </Style>
    <Style Selector="GridSplitter:pointerover">
        <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" />
        <Setter Property="Opacity" Value="0.4" />
    </Style>

    <!-- ===== Accent button (primary action) ===== -->
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- ===== Standard horizontal separator ===== -->
    <Style Selector="Separator.standard">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumBrush}" />
        <Setter Property="Margin" Value="0,4" />
    </Style>

</Styles>
